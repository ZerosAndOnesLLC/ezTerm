---
// site/src/pages/screenshots.astro
import '../styles/global.css';
import MockupFrame from '../components/MockupFrame.astro';
import SiteFooter from '../components/SiteFooter.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';

const BASE = import.meta.env.BASE_URL;
const SITE = 'https://ezterm.zerosandones.us';
const shots = [
  {
    src: `${BASE}screenshots/sftp-pane.png`,
    alt: 'ezTerm SSH tab with the SFTP side-pane docked, browsing the remote home directory',
    caption: 'SFTP side-pane — file browser docked beside the active SSH tab.',
  },
  {
    src: `${BASE}screenshots/terminal-grid.png`,
    alt: 'ezTerm window with four terminal panes arranged in a 2×2 grid layout',
    caption: 'Split panes — 2×2 grid, same connection or different.',
  },
  {
    src: `${BASE}screenshots/terminal-stacked.png`,
    alt: 'ezTerm window with four terminal panes stacked horizontally',
    caption: 'Horizontal stacks — perfect for tailing logs across a fleet.',
  },
  {
    src: `${BASE}screenshots/session-config-general.png`,
    alt: 'ezTerm session configuration dialog — General tab showing SSH connection details',
    caption: 'Session setup — one tabbed dialog covers SSH, WSL, and local shells.',
  },
  {
    src: `${BASE}screenshots/session-config-advanced.png`,
    alt: 'ezTerm session configuration dialog — Advanced tab with keepalive, compression, and X11 forwarding toggle',
    caption: 'Advanced options — keepalive, compression, X11 forwarding.',
  },
  {
    src: `${BASE}screenshots/port-forwarding.png`,
    alt: 'ezTerm port forwarding dialog — Local, Remote, and Dynamic SOCKS5 tunnel types',
    caption: 'Port forwards — Local, Remote, or Dynamic SOCKS5, saved per session.',
  },
  {
    src: `${BASE}screenshots/session-create.png`,
    alt: 'ezTerm new session dialog — creating a Proxmox-01 SSH session',
    caption: 'New session — quick capture of host, port, username, and folder.',
  },
];
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>Screenshots — ezTerm</title>
    <meta name="description" content="Screenshots of ezTerm — sessions sidebar, tabbed terminals, SFTP side-pane, split panes, session config, and port forwarding." />
    <link rel="canonical" href={`${SITE}/screenshots/`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="ezTerm Screenshots" />
    <meta property="og:description" content="Screenshots of ezTerm — sessions sidebar, tabbed terminals, SFTP side-pane, split panes, session config, and port forwarding." />
    <meta property="og:url" content={`${SITE}/screenshots/`} />
    <meta property="og:image" content={`${SITE}/og.png`} />
    <meta property="og:site_name" content="ezTerm" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="ezTerm Screenshots" />
    <meta name="twitter:description" content="Screenshots of ezTerm in action." />
    <meta name="twitter:image" content={`${SITE}/og.png`} />
    <link rel="icon" type="image/png" href={`${BASE}ezterm-icon.png`} />
    <GoogleAnalytics />
  </head>
  <body class="bg-site-bg text-site-fg">
    <header class="border-b border-site-border">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href={BASE} class="flex items-center font-bold tracking-tight">
          <img src={`${BASE}ezterm-icon.png`} alt="ezTerm" width="40" height="40" class="h-10 w-auto" />
        </a>
        <nav class="flex items-center gap-6 text-sm text-site-fg-muted">
          <a href={`${BASE}docs/`} class="hover:text-site-fg">Docs</a>
          <a href={`${BASE}screenshots/`} class="text-site-fg">Screenshots</a>
          <a href={`${BASE}changelog/`} class="hover:text-site-fg">Changelog</a>
          <a href="https://github.com/ZerosAndOnesLLC/ezTerm" class="hover:text-site-fg">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <h1 class="text-4xl font-bold tracking-tight mb-2">Screenshots</h1>
      <p class="text-site-fg-muted mb-10">ezTerm in action.</p>

      <div class="space-y-10">
        {shots.map((s) => (
          <MockupFrame src={s.src} alt={s.alt} caption={s.caption} />
        ))}
      </div>
    </main>

    <SiteFooter />
  </body>
</html>
